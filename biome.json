{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/build/**/*",
			"!**/dist/**/*",
			"!**/coverage/**/*",
			"!**/node_modules/**/*",
			"!**/.vscode/**/*",
			"!**/.idea/**/*",
			"!**/.git/**/*"
		]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	}
}
